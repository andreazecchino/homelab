#cloud-config

# Set the device's hostname and updated /etc/hosts
hostname: <replace with hostname>
manage_etc_hosts: true

# Set up the keyboard layout
keyboard:
  model: pc105
  layout: it

# Set the system timezone
timezone: Europe/Rome

# Enable the SSH server on first boot and disable SSH password authentication
enable_ssh: true
ssh_pwauth: false

# Set users and permissions
users:
  - name: <replace with user>
    groups: <replace with groups>
    shell: /bin/bash
    lock_passwd: true # disable password login
    ssh_authorized_keys:
      - <replace with SSH public key>
    sudo: ALL=(ALL) NOPASSWD:ALL # allow passwordless sudo for this user



